# Zelte Environment Configuration - Zero-Config Setup
# Copy this file to .zelte.env (or .env) to auto-load environment variables
# DO NOT commit .zelte.env to version control - add it to .gitignore!

# API Configuration (Auto-detected by zelte run)
API_URL=http://localhost:3000
BASE_URL=http://localhost:3000
ZELTE_URL=http://localhost:3000

# Authentication Tokens
API_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
ADMIN_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
AUTH_TOKEN=your-auth-token-here

# Test Credentials
TEST_EMAIL=test@mail.com
TEST_PASSWORD=123456
TEST_USER_ID=12345
TEST_PROJECT_ID=projects/proj-001

# Third-party API Keys
STRIPE_API_KEY=sk_test_your_stripe_key_here
SENDGRID_API_KEY=SG.your_sendgrid_key_here
GITHUB_TOKEN=ghp_your_github_token_here

# Configuration
DEBUG=true
VERBOSE=false
ENVIRONMENT=development
LOG_LEVEL=info

# Timeouts (milliseconds)
TIMEOUT=30000
REQUEST_TIMEOUT=5000
