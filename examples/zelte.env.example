# Environment Variables Example File
# Copy this file to .zelte.env and add your actual credentials
# DO NOT commit .zelte.env to version control

# API Authentication
API_BASE_URL=https://api.example.com
API_BEARER_TOKEN=your-bearer-token-here
API_USERNAME=your-username-here
API_PASSWORD=your-password-here



# Third-party API Keys
STRIPE_API_KEY=sk_test_your_stripe_key_here
SENDGRID_API_KEY=SG.your_sendgrid_key_here

 
# Development Environment
NODE_ENV=development
DEBUG=true